          "title": "Policy"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        },
        "request_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Stable per-turn identifier stamped by the transport adapter.",
          "title": "Request Id"
        },
        "result": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Result"
        },
        "run_id": {
          "title": "Run Id",
          "type": "string"
        },
        "schema_version": {
          "default": 1,
          "description": "Version of the RuntimeEvent schema this event conforms to.",
          "title": "Schema Version",
          "type": "integer"
        },
        "tool": {
          "title": "Tool",
          "type": "string"
        },
        "type": {
