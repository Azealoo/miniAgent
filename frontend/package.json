{
  "name": "mini-openclaw-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NEXT_DIST_DIR=.next-dev next dev",
    "build": "NEXT_DIST_DIR=.next-build next build",
    "build:e2e": "NEXT_DIST_DIR=.next-e2e-build next build",
    "start": "NEXT_DIST_DIR=.next-build next start",
    "start:e2e": "NEXT_DIST_DIR=.next-e2e-build next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "PLAYWRIGHT_BROWSERS_PATH=0 npm run build:e2e && PLAYWRIGHT_BROWSERS_PATH=0 playwright test"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "clsx": "^2.1.0",
    "highlight.js": "^11.9.0",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.400.0",
    "next": "^14.2.0",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^9.0.0",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^2.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "eslint": "^8",
    "eslint-config-next": "^14.2.0",
    "jsdom": "^29.0.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.0",
    "typescript": "^5",
    "vitest": "^4.1.1"
  }
}
